    <link rel="shortcut icon" href="https://store.wacoal.jp/on/demandware.static/Sites-StoreWacoal-Site/-/default/dw7da22f6f/images/favicon.ico">
    <meta name="format-detection" content="telephone=no">
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
