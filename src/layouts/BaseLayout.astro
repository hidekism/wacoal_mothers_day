---
import headerHtml from '../components/fragments/header.html?raw';
import footerInnerHtml from '../components/fragments/footer.html?raw';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogpImageUrl?: string;
}
const {
  title = '',
  description = '',
  keywords = '',
  ogpImageUrl = ''
} = Astro.props;
const staticlink = '?$staticlink$';
