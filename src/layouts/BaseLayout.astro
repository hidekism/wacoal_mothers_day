    <meta property="og:url" content="https://store.wacoal.jp/topics/campaign/bratop_collection.html">
    <meta property="og:image" content={ogpImageUrl+staticlink}>
    <meta property="og:description" content={description}>
    <meta property="og:locale" content="ja_JP">
